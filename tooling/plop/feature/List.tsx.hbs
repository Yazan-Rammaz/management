"use client";

import { AnimatedCard } from "@/components/motion/AnimatedCard";
import type { {{pascalCase name}} } from "../schema";

export function {{pascalCase name}}List({ items }: { items: {{pascalCase name}}[] }) {
  if (items.length === 0) {
    return <p className="fz-16 opacity-60">No {{kebabCase name}}s yet.</p>;
  }

  return (
    <div className="grid grid-cols-1 gap-16 md:grid-cols-2 lg:grid-cols-3">
      {items.map((item) => (
        <AnimatedCard key={item.id} layoutId={`{{kebabCase name}}-${item.id}`}>
          <span className="fz-16 font-medium">{item.name}</span>
        </AnimatedCard>
      ))}
    </div>
  );
}
